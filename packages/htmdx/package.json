{
  "name": "@wix/htmdx",
  "version": "1.0.10",
  "description": "Render editable HTMDX source inside plain HTML artifacts.",
  "keywords": [
    "agents",
    "artifacts",
    "custom-element",
    "html",
    "mdx"
  ],
  "license": "MIT",
  "author": "Vlad Tansky (https://github.com/vltansky)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wix-incubator/htmdx.git",
    "directory": "packages/htmdx"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/test/**",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "unpkg": "./dist/browser.js",
  "jsdelivr": "./dist/browser.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/src/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "yarn typecheck && rollup -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "jsdom": "^27.2.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "rollup": "^4.61.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
